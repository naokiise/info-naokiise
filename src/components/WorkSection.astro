---
import type { WorkSection as WorkSectionType } from "../lib/types";
import { slugify } from "../lib/slug";

interface Props {
  section: WorkSectionType;
  defaultOpen?: boolean;
}

const { section, defaultOpen = false } = Astro.props;
const sectionId = slugify(section.name);
const hasVenue = section.columns.includes("venue");
const hasText = section.columns.includes("text");
const hasPublisher = section.columns.includes("publisher");
---

<details
  id={`work-${sectionId}`}
  class:list={["work-section", section.nofill && "work-section--nofill"]}
  open={defaultOpen || undefined}
>
  <summary class="work-section__summary">
    <span class="work-section__toggle" aria-hidden="true"></span>
    <span class="work-section__title">{section.name}</span>
  </summary>
  <ul class="work-list">
    {
      section.rows.map((row) => (
        <li class="work-item">
          <span class="work-item__year">{row.year}</span>
          <div class="work-item__body">
            <p class="work-item__title">{row.title}</p>
            {hasText && row.text && <p class="work-item__meta">{row.text}</p>}
            {hasVenue && row.venue && <p class="work-item__meta">{row.venue}</p>}
            {hasPublisher && row.publisher && (
              <p class="work-item__meta">{row.publisher}</p>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</details>
